# Server
PORT=8080
NODE_ENV=production

# Database (DigitalOcean MySQL sweetbonb-tgbot)
DATABASE_URL=mysql://sweetbonb-tgbot:YOUR_PASSWORD@db-wwferic-do-user-2791833-0.g.db.ondigitalocean.com:25060/sweetbonb-tgbot?ssl-mode=REQUIRED

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

# Bot mode: live | test | admin
BOT_MODE=live

# Optional overrides (defaults loaded from n8n_bot_info table)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=

# Webhook (set after DO deploy)
WEBHOOK_BASE_URL=https://your-app.ondigitalocean.app
TELEGRAM_WEBHOOK_SECRET=change-me-to-random-string

# Chat history window for AI context
CHAT_HISTORY_LIMIT=20
